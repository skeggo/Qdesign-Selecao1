# MongoDB
MONGODB_URI=mongodb://localhost:27017/qdesign

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRATION=7d

# Server
PORT=3001

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# Rate limiting (TTL in ms, limit = max requests per TTL window)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Python service URLs
RETRIEVE_API_URL=http://localhost:8002
AI_COSCIENTIST_API_URL=http://localhost:8003
